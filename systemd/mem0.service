[Unit]
Description=mem0 v2.0.4 WSL-native server (v0.12 agentic-memory-stack)
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/apps/mem0-server
# v0.29.3: R4 raw-trace fallback ON by default in production (its episodic
# test-pollution gate was cleared + live-verified in v0.29.2). Surfaces ONE
# semantic-relevant past-episode snippet ONLY when condensed search returns 0
# memories; off-domain prompts abstain (cosine floor). Disable with =0 if needed.
Environment=MEM0_RAW_FALLBACK_ENABLED=1
# v0.29.4 item 1: extend Weibull freshness to the time-sensitive tiers (evidence,
# temporal) on the durable read path — atemporal canonical/stable/insight never decay.
# GENTLE (365d half-life default); demotes only genuinely-stale evidence. Disable with =0.
Environment=MEM0_DURABLE_FRESHNESS_ENABLED=1
# v1.0 R7 (Phase 7A): operator-agnostic default tenant for the /v1/context/bundle
# proactive search. The installer substitutes the __WSL_USER__ sentinel with the
# install user (1-wsl-services.sh systemd sed) so a third-party box queries its
# own tenant; app.py falls back to "default" if unset.
Environment=MEM0_DEFAULT_USER_ID=__WSL_USER__
# v0.19 Phase H key chain: private tmpfs runtime dir + best-effort DPAPI key
# fetch before start. The '-' prefix keeps fresh/plaintext-mode boxes safe:
# the fetch fails soft and canonical_key_provider falls through to plaintext.
RuntimeDirectory=mem0
RuntimeDirectoryMode=0700
ExecStartPre=-%h/apps/mem0-server/dpapi-fetch-key.sh
ExecStart=%h/apps/mem0-server/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 18791
Restart=on-failure
RestartSec=5
MemoryMax=2G

[Install]
WantedBy=default.target
