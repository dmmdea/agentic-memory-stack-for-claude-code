# Normalize ALL text files to LF. core.autocrlf=true on Windows was smudging committed
# files to CRLF on checkout — which breaks WSL bash scripts ("$'\r': command not found")
# and causes spurious R9 drift (several scripts/configs are SHA256-compared repo-vs-deployed,
# so the committed bytes, the working checkout, and the deployed copy must be byte-identical).
* text=auto eol=lf

# Explicit pins for the WSL-executed + R9-deployed surface (belt-and-suspenders over the catch-all):
*.sh   text eol=lf
*.py   text eol=lf
*.ps1  text eol=lf
*.json text eol=lf
*.bats text eol=lf
claude-config/model-tiers.json text eol=lf

# Binary — never EOL-convert (also auto-detected by `text=auto`, pinned here for safety):
*.gguf binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.gz   binary
*.zip  binary
*.db   binary
*.xlsx binary
